SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=

# Frontend origins allowed by CORS (comma-separated)
CORS_ORIGINS=https://your-frontend-domain.example

# Public URL used in invite links
APP_PUBLIC_URL=https://your-frontend-domain.example

# Optional aliases also supported by config
MOMENTRA_APP_INVITE_BASE_URL=https://your-frontend-domain.example
MOMENTRA_RESEND_API_KEY=
MOMENTRA_RESEND_FROM=Momentra <invite@your-domain.example>

# Firebase project metadata
FIREBASE_PROJECT_ID=your-firebase-project-id
#
# Credentials — pick ONE:
#
# (A) File on disk (recommended for Dockge / Compose): place JSON at
#     ./secrets/firebase-service-account.json (next to docker-compose.yml). In the
#     container use the mounted path (see docker-compose environment):
FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase.json
#
# (B) FIREBASE_SERVICE_ACCOUNT_JSON in .env must be ONE LINE (minified JSON).
#     Multi-line / pretty-printed JSON in .env will error:
#     unexpected character "\"" in variable name
#     Minify: jq -c . < your-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

API_HOST=0.0.0.0
API_PORT=6000
