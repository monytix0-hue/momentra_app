SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=

# Frontend origins allowed by CORS (comma-separated)
CORS_ORIGINS=https://your-frontend-domain.example

# Public URL used in invite links
APP_PUBLIC_URL=https://your-frontend-domain.example

# Optional aliases also supported by config
MOMENTRA_APP_INVITE_BASE_URL=https://your-frontend-domain.example
MOMENTRA_RESEND_API_KEY=
MOMENTRA_RESEND_FROM=Momentra <invite@your-domain.example>

# Firebase project metadata
FIREBASE_PROJECT_ID=your-firebase-project-id
#
# Credentials — pick ONE (do not set FIREBASE_CREDENTIALS_PATH if you use JSON only):
#
# (A) FIREBASE_SERVICE_ACCOUNT_JSON — one line (minified). Omit FIREBASE_CREDENTIALS_PATH.
#     jq -c . < your-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# (B) File mount (Compose/Dockge): put JSON at ./secrets/firebase-service-account.json,
#     set FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase.json in .env, and uncomment
#     the volumes block in docker-compose.yml.

API_HOST=0.0.0.0
API_PORT=6000
