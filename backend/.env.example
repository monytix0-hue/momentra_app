SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=

# Frontend origins allowed by CORS (comma-separated)
CORS_ORIGINS=https://your-frontend-domain.example

# Public URL used in invite links
APP_PUBLIC_URL=https://your-frontend-domain.example

# Optional aliases also supported by config
MOMENTRA_APP_INVITE_BASE_URL=https://your-frontend-domain.example
MOMENTRA_RESEND_API_KEY=
MOMENTRA_RESEND_FROM=Momentra <invite@your-domain.example>

# Firebase project metadata
FIREBASE_PROJECT_ID=your-firebase-project-id
# In Docker compose this is overridden to /run/secrets/firebase.json
FIREBASE_CREDENTIALS_PATH=./secrets/firebase-service-account.json

API_HOST=0.0.0.0
API_PORT=8000
