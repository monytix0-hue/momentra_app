SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=

# Frontend origins allowed by CORS (comma-separated). Must include every browser origin
# that calls this API (e.g. https://momentra.tech). Not the API host (e.g. backend.mallaapp.org).
CORS_ORIGINS=https://your-frontend-domain.example
# Optional regex for extra origins (default allows all https://*.vercel.app preview deploys).
# Set to empty to disable: CORS_ORIGIN_REGEX=
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Public URL used in invite links
APP_PUBLIC_URL=https://your-frontend-domain.example

# Optional aliases also supported by config
MOMENTRA_APP_INVITE_BASE_URL=https://your-frontend-domain.example
MOMENTRA_RESEND_API_KEY=
MOMENTRA_RESEND_FROM=Momentra <invite@your-domain.example>

# Firebase project metadata
FIREBASE_PROJECT_ID=your-firebase-project-id
#
# Credentials — pick ONE (do not set FIREBASE_CREDENTIALS_PATH if you use JSON only):
#
# (A) Recommended for Dokploy / multiline-safe: base64 the whole JSON file (one line in UI).
#     macOS/Linux:  base64 -i your-adminsdk.json | tr -d '\n'
#     Or:            base64 < your-adminsdk.json | tr -d '\n'
# FIREBASE_SERVICE_ACCOUNT_JSON_B64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...
#
# (B) One-line JSON (OUTPUT of jq — not the jq command; do not paste pretty-printed JSON).
#     jq -c . your-adminsdk.json   → paste that single line
#     FIREBASE_CREDENTIALS_JSON is an alias for the same inline JSON.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# Only on GCP with metadata-based ADC and no JSON file:
# FIREBASE_ALLOW_APPLICATION_DEFAULT_CREDENTIALS=true
#
# (B) File mount: put JSON at ./secrets/firebase-service-account.json (next to compose),
#     then merge docker-compose.firebase-file.yml with docker-compose.yml (see that file).
#     Do not add environment/volumes for Firebase to docker-compose.yml unless the file exists,
#     or Compose/Dockge will fail on the bind mount.

API_HOST=0.0.0.0
API_PORT=8002
